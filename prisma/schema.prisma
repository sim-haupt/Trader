generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TradeSide {
  LONG
  SHORT
}

enum ExecutionAction {
  BUY
  SELL
}

enum ExecutionSource {
  IMPORTED
  SYNTHETIC
}

enum ImportStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum AccountScope {
  SIMULATOR
  LIVE
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  role         UserRole      @default(USER)
  activeAccountScope AccountScope @default(SIMULATOR)
  liveDataStartDate DateTime?
  defaultCommission Decimal   @default(0) @db.Decimal(18, 4)
  defaultFees  Decimal        @default(0) @db.Decimal(18, 4)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  trades       Trade[]
  imports      TradeImport[]
  savedTags    SavedTag[]
  savedStrategies SavedStrategy[]
  journalDays  JournalDay[]
}

model Trade {
  id                   String           @id @default(cuid())
  userId               String
  accountScope         AccountScope     @default(SIMULATOR)
  symbol               String
  side                 TradeSide
  quantity             Decimal          @db.Decimal(18, 4)
  entryPrice           Decimal          @db.Decimal(18, 4)
  exitPrice            Decimal?         @db.Decimal(18, 4)
  entryDate            DateTime
  exitDate             DateTime?
  fees                 Decimal          @default(0) @db.Decimal(18, 4)
  strategy             String?
  tags                 String?
  notes                String?
  grossPnl             Decimal?         @db.Decimal(18, 4)
  netPnl               Decimal?         @db.Decimal(18, 4)
  entryVolume          Decimal?         @db.Decimal(20, 4)
  entryRelativeVolume  Decimal?         @db.Decimal(18, 4)
  instrumentFloat      Decimal?         @db.Decimal(20, 4)
  entryPriorCloseDiffPercent Decimal?   @db.Decimal(18, 4)
  marketDataFeed       String?
  marketDataNeedsBackfill Boolean       @default(false)
  reportedExecutionCount Int?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions           TradeExecution[]

  @@index([userId, accountScope, entryDate])
  @@index([userId, accountScope, symbol])
  @@index([userId, accountScope, strategy])
}

model TradeExecution {
  id            String          @id @default(cuid())
  tradeId        String
  occurredAt     DateTime
  quantity       Decimal         @db.Decimal(18, 4)
  price          Decimal         @db.Decimal(18, 4)
  action         ExecutionAction
  sequence       Int
  positionAfter  Decimal?        @db.Decimal(18, 4)
  source         ExecutionSource @default(IMPORTED)
  createdAt      DateTime        @default(now())
  trade          Trade           @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId, occurredAt])
  @@unique([tradeId, sequence])
}

model TradeImport {
  id             String        @id @default(cuid())
  userId         String
  accountScope   AccountScope  @default(SIMULATOR)
  fileName       String
  status         ImportStatus
  totalRows      Int
  successfulRows Int
  failedRows     Int
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  errors         ImportError[]

  @@index([userId, accountScope, createdAt])
}

model ImportError {
  id          String      @id @default(cuid())
  importId    String
  rowNumber   Int
  rawData     Json
  errorMessage String
  tradeImport TradeImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
}

model SavedTag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, createdAt])
}

model SavedStrategy {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, createdAt])
}

model JournalDay {
  id        String   @id @default(cuid())
  userId    String
  accountScope AccountScope @default(SIMULATOR)
  dayKey    String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountScope, dayKey])
  @@index([userId, accountScope, dayKey])
}
